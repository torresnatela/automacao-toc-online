{"nodes": [{"id": "docs_architecture_monorepo_two_deployables", "label": "Monorepo com dois deployables", "file_type": "rationale", "source_file": "docs/architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A automa\u00e7\u00e3o de browser (Playwright) exige processo persistente, sess\u00f5es longas, 2FA e download de PDFs \u2014 incompat\u00edvel com o modelo serverless/stateless da Vercel. O dashboard/API/auth \u00e9 ideal para a Vercel. Ambos compartilham packages/* e falam com o mesmo Supabase."}, {"id": "docs_architecture_apps_web", "label": "apps/web (Next.js App Router \u2192 Vercel)", "file_type": "concept", "source_file": "docs/architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_architecture_apps_worker", "label": "apps/worker (Node + Playwright RPA)", "file_type": "concept", "source_file": "docs/architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Roda fora da Vercel (Fly.io / Railway / container) por exigir processo de longa dura\u00e7\u00e3o; nesta fase \u00e9 apenas scaffold."}, {"id": "docs_architecture_supabase", "label": "Supabase (Postgres verdade + Auth + Storage)", "file_type": "concept", "source_file": "docs/architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_architecture_packages_core", "label": "packages/core (Tracer/Logger + tipos de dom\u00ednio)", "file_type": "concept", "source_file": "docs/architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "N\u00e3o depende de Next nem do worker; s\u00f3 de @toc/db e tipos. Test\u00e1vel isolada."}, {"id": "docs_architecture_packages_db", "label": "packages/db (schema Drizzle + client pg)", "file_type"