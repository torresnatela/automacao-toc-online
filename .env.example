# Supabase local. Este projeto usa portas deslocadas (+100) para coexistir com
# outro stack Supabase na máquina. Confirme os valores com `supabase status`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key do `supabase status`>
SUPABASE_SERVICE_ROLE_KEY=<service_role key do `supabase status`>
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres
